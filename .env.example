# Gemini API Key for LLM and Embeddings
GEMINI_API_KEY=your_gemini_api_key_here

# Neon PostgreSQL Database URL
NEON_DB_URL=postgresql://user:password@host/dbname?sslmode=require

# Internal API Key for security (Required in production)
# Client must send header: X-API-Key: UQd98E541HlDeXi0mORRnaShL3neNsfOQHBfm0NOt0Y
APP_SERVICE_KEY=api_service_xyz

# Analytics Configuration (Optional)
# Enable/disable analytics middleware
ENABLE_ANALYTICS=true
# Log level for analytics (INFO, DEBUG, WARNING, ERROR)
ANALYTICS_LOG_LEVEL=INFO
# Optional: External analytics service endpoint
# ANALYTICS_EXTERNAL_ENDPOINT=https://your-analytics-service.com/api/events
# Optional: API key for external analytics service
# ANALYTICS_API_KEY=your_analytics_api_key_here
